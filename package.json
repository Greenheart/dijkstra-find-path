{
  "name": "dijkstrats",
  "version": "1.0.3",
  "description": "TypeScript implementation of Dijkstra's single-source shortest-paths algorithm, including performance optimizations based on the `heapq` Python library.",
  "keywords": [
    "dijkstra",
    "graph",
    "path",
    "pathfinding",
    "search",
    "shortest"
  ],
  "homepage": "https://github.com/Greenheart/dijkstrats",
  "bugs": {
    "url": "https://github.com/Greenheart/dijkstrats/issues"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Greenheart/dijkstrats.git"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "exports": {
    ".": "./dist/dijkstra.mjs",
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "test": "vitest",
    "format": "oxfmt",
    "lint": "oxfmt --check && oxlint",
    "bench": "node --expose-gc benchmarks/bench.ts"
  },
  "devDependencies": {
    "@arethetypeswrong/core": "^0.18.2",
    "@types/node": "^25.3.5",
    "oxfmt": "^0.36.0",
    "oxlint": "^1.51.0",
    "oxlint-tsgolint": "^0.16.0",
    "publint": "^0.3.18",
    "tinybench": "^6.0.0",
    "tsdown": "^0.21.0",
    "typescript": "^6.0.1-rc",
    "vitest": "^4.0.18"
  },
  "pnpm": {
    "overrides": {
      "vite": "8.0.0-beta.16",
      "typescript": "6.0.1-rc"
    },
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
